{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.{ts,tsx,js,jsx}", "src/main.{ts,tsx,js,jsx}", "tests/setup.ts"],
  "ignorePatterns": ["src/components/ui/**", "src/hooks/use-mobile.ts", "src/api/schema.ts"],
  "ignoreDependencies": [
    "radix-ui",
    "lucide-react",
    "@tanstack/react-query-devtools",
    "@tanstack/react-devtools",
    "@tanstack/router-plugin",
    "class-variance-authority",
    "openapi-fetch",
    "cmdk",
    "date-fns",
    "react-day-picker"
  ],
  "ignoreExports": [
    {
      "file": "src/api/*",
      "exports": ["*"]
    }
  ],
  "rules": {
    "unused-dependencies": "warn",
    "unused-files": "error",
    "unused-exports": "warn",
    "unused-types": "off"
  }
}
